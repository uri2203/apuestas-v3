# ── Autenticación ─────────────────────────────────────────────────────────────
# Contraseña del dashboard (OBLIGATORIO — no tiene default en producción)
APP_PASSWORD=tu-contrasena-segura-aqui

# Clave para firmar cookies de sesión (genera con: python -c "import secrets; print(secrets.token_hex(32))")
# Si se cambia, todas las sesiones activas se invalidan
SESSION_SECRET=genera-un-valor-aleatorio-de-64-chars

# Duración de sesión en días (default: 7)
SESSION_DAYS=7

# ── APIs externas ─────────────────────────────────────────────────────────────
# Odds en tiempo real — gratis en the-odds-api.com (500 req/mes)
ODDS_API_KEY=tu-key-aqui

# Datos reales Liga MX — gratis en api-football.com (100 req/día)
# Registrate en rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=tu-key-aqui

# Clima por ciudad — gratis en openweathermap.org (1000 req/día)
OPENWEATHER_KEY=tu-key-aqui

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Token del bot (obtener con @BotFather)
TELEGRAM_TOKEN=tu-token-aqui

# Chat ID al que enviar alertas (obtener con @userinfobot)
TELEGRAM_CHAT_ID=tu-chat-id-aqui

# Secret para validar el webhook HMAC (genera con: python -c "import secrets; print(secrets.token_hex(32))")
# Configurar también en: https://api.telegram.org/bot<TOKEN>/setWebhook?secret_token=<este-valor>
TELEGRAM_WEBHOOK_SECRET=genera-un-valor-aleatorio

# ── Email (resumen diario + alertas) ─────────────────────────────────────────
EMAIL_FROM=tu-email@gmail.com
EMAIL_PASSWORD=contraseña-de-aplicacion-gmail
EMAIL_TO=destinatario@gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ── Base de datos ─────────────────────────────────────────────────────────────
# Ruta del archivo SQLite (default: apuestaspro.db en el directorio raíz)
DB_PATH=apuestaspro.db
